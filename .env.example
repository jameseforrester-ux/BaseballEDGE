# ─── TELEGRAM ─────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ─── GOOGLE CLOUD (for BigQuery Statcast) ─────────────────────
# Either provide a service-account JSON path OR set credentials inline
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
GCP_PROJECT_ID=your-gcp-project-id

# ─── POLYMARKET ────────────────────────────────────────────────
# No key needed for public read; set if you have an account API key
POLYMARKET_API_KEY=

# ─── OPTIONAL TUNING ──────────────────────────────────────────
# Confidence threshold to flag a "value" edge (default 5%)
VALUE_EDGE_THRESHOLD=0.05
# Minimum implied probability difference to surface a bet
MIN_EDGE_PCT=3
